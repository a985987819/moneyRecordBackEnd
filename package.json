{
  "name": "moneyBackend",
  "version": "1.0.0",
  "description": "记账后端API服务",
  "scripts": {
    "dev": "bun --bun run --watch src/index.ts",
    "dev:hot": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Linting...' && bun run typecheck",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:init": "bun run src/scripts/init-db.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.9",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.10"
  }
}
